   "source": [
    "import pandas as pd
import numpy as np
from src.data_cleaner import handle_missing_values, remove_outliers_iqr, scale_features, encode_categorical_features

# Generate a sample dataset
data = {
    'Feature1': [10, 20, np.nan, 40, 50, 1000], # Outlier and missing
    'Feature2': [1.1, 2.2, 3.3, 4.4, np.nan, 6.6],
    'Category': ['A', 'B', 'A', 'C', 'B', 'A'],
    'City': ['NY', 'LA', 'NY', 'CHI', 'LA', np.nan],
    'Target': [0, 1, 0, 1, 0, 1]
}
df = pd.DataFrame(data)
print("Original DataFrame:\
", df)

# 1. Handle Missing Values
# Impute numerical columns with mean
df_imputed_num = handle_missing_values(df, strategy='mean', columns=['Feature1', 'Feature2'])
print("\\nDataFrame after numerical imputation:\
", df_imputed_num)

# Impute categorical columns with most frequent
df_imputed_cat = handle_missing_values(df_imputed_num, strategy='most_frequent', columns=['City'])
print("\\nDataFrame after categorical imputation:\
", df_imputed_cat)

# 2. Remove Outliers
df_no_outliers = remove_outliers_iqr(df_imputed_cat, 'Feature1')
print("\\nDataFrame after outlier removal from Feature1:\
", df_no_outliers)

# Reset index after removing rows
df_no_outliers = df_no_outliers.reset_index(drop=True)

# 3. Scale Numerical Features
df_scaled = scale_features(df_no_outliers, columns=['Feature1', 'Feature2'], scaler_type='standard')
print("\\nDataFrame after standard scaling Feature1 and Feature2:\
", df_scaled)

# 4. Encode Categorical Features
df_encoded = encode_categorical_features(df_scaled, columns=['Category', 'City'], encoder_type='onehot')
print("\\nDataFrame after one-hot encoding Category and City:\
", df_encoded)

print("\\nFinal Preprocessed DataFrame Head:\
", df_encoded.head())"
   ]
  }
