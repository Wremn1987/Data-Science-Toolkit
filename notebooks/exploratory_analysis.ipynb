   "source": [
    "import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from src.eda_utils import get_dataframe_info, get_descriptive_stats, plot_numerical_distributions, plot_categorical_distributions, plot_correlation_heatmap

# Generate a sample dataset
data = {
    'Age': np.random.randint(18, 65, 100),
    'Salary': np.random.randint(30000, 120000, 100),
    'Gender': np.random.choice(['Male', 'Female'], 100),
    'City': np.random.choice(['New York', 'Los Angeles', 'Chicago', 'Houston'], 100),
    'ExperienceYears': np.random.randint(0, 20, 100),
    'PurchaseAmount': np.random.rand(100) * 1000
}
df = pd.DataFrame(data)

# Introduce some missing values and outliers for demonstration
df.loc[5, 'Age'] = np.nan
df.loc[10, 'Salary'] = 500000 # Outlier
df.loc[15, 'Gender'] = np.nan

print("Initial DataFrame Head:\
", df.head())

# 1. Get DataFrame Information
get_dataframe_info(df)

# 2. Get Descriptive Statistics
get_descriptive_stats(df, include_categorical=True)

# 3. Plot Numerical Distributions
plot_numerical_distributions(df, columns=['Age', 'Salary', 'ExperienceYears', 'PurchaseAmount'])

# 4. Plot Categorical Distributions
plot_categorical_distributions(df, columns=['Gender', 'City'])

# 5. Plot Correlation Heatmap
plot_correlation_heatmap(df, numerical_columns=['Age', 'Salary', 'ExperienceYears', 'PurchaseAmount'])"
   ]
